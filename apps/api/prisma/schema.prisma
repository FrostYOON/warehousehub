generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// 사용자 권한
/// - ADMIN: 회사 전체 관리자
/// - WH_MANAGER: 창고 관리자 (입고/출고/조정 가능)
/// - DELIVERY: 배송 담당자 (배송 확인/출고 검토)
/// - ACCOUNTING: 회계 담당자 (재고 조회)
/// - SALES: 영업 담당자 (재고/출고 조회)
enum Role {
  ADMIN
  WH_MANAGER
  DELIVERY
  ACCOUNTING
  SALES
}

/// 창고 타입 (회사당 DRY/COOL/FRZ 1개씩 존재)
enum StorageType {
  DRY // 상온
  COOL // 냉장
  FRZ // 냉동
}

/// 재고 원장 트랜잭션 유형
/// 모든 재고 증감은 이 테이블에 기록됨 (Audit Trail 목적)
enum InventoryTxType {
  INBOUND_CONFIRM // 입고 확정 (onHand 증가)
  OUTBOUND_CONFIRM // 출고 확정 (onHand 감소)
  PICK_RESERVE // 픽 예약 (reserved 증가)
  PICK_RELEASE // 픽 취소 (reserved 감소)
  ADJUSTMENT // 관리자 수량 조정
  RETURN_RESTOCK // 리턴 재입고
  RETURN_DISCARD // 리턴 폐기
  TRANSFER // 창고 간 재고 이동
}

/// 엑셀 입고 업로드 상태
enum InboundUploadStatus {
  UPLOADED
  CONFIRMED
  CANCELLED
}

/// 출고 오더 상태
enum OutboundStatus {
  DRAFT // 출고 요청
  PICKING // 픽킹 중
  PICKED // 픽 완료
  READY_TO_SHIP // 검수 완료/출발 준비
  SHIPPING // 배송중
  DELIVERED // 배송(출고) 완료
  CANCELLED // 취소
}

/// 출고 라인 상태
enum OutboundLineStatus {
  ACTIVE
  CANCELLED
  SHORT_SHIPPED // 일부만 배송됨(파손/품절 등)
  DELIVERED // 라인 단위 완료
}

/// 픽 방식
/// AUTO_FEFO : 시스템 자동 선입선출
/// MANUAL    : 창고 담당자가 특정 Lot 선택
enum PickSource {
  AUTO_FEFO
  MANUAL
}

enum ReturnStatus {
  RECEIVED // 리턴 접수됨
  DECIDED // 재입고/폐기 결정 완료
  COMPLETED // 재고 반영까지 완료
  CANCELLED
}

enum ReturnLineDecision {
  RESTOCK // 재입고
  DISCARD // 폐기
}

/// 창고 간 재고 이동 상태
enum TransferStatus {
  PENDING // 요청됨
  CONFIRMED // 확정 완료
  CANCELLED // 취소
}

/// 재고 실사 상태
enum StocktakingStatus {
  DRAFT // 계획 생성
  IN_PROGRESS // 실사 입력 중
  CONFIRMED // 확정 (재고 반영 완료)
  CANCELLED // 취소
}

/// 입고 예정(ASN) 상태
enum AsnStatus {
  PENDING // 입고 신청됨
  SHIPPED // 원본 지사 출고 완료
  RECEIVED // 대상 지사 입고 확정
  CANCELLED // 취소
}

/// 하나의 회사(테넌트)
/// 모든 데이터는 companyId 기준으로 격리됨
model Company {
  id   String @id @default(uuid())
  name String @unique

  /// 회사/창고 주소 (날씨 조회용)
  address    String?
  postalCode String?
  city       String?
  state      String?
  country    String?  // ISO 3166-1 alpha-2
  lat        Decimal? @db.Decimal(10, 7)
  lng        Decimal? @db.Decimal(10, 7)

  users      User[]
  branches   Branch[]
  warehouses Warehouse[]
  items      Item[]
  customers  Customer[]

  // 재고 도메인
  lots           Lot[]
  stocks         Stock[]
  inventoryTxes  InventoryTx[]
  inboundUploads InboundUpload[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  outboundOrders  OutboundOrder[]
  pickAllocations PickAllocation[]
  returnReceipts  ReturnReceipt[]
  temperatureLogs TemperatureLog[]
  transfers       Transfer[]
  stocktakings    Stocktaking[]
  asns            Asn[]
}

/// 온도·날씨 모니터링 로그
/// COOL(냉장 2~8°C), FRZ(냉동 -18°C 이하) 온도 기입 및 적정 여부 기록
model TemperatureLog {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// 조회 시점 위치 (날씨 API용)
  locationLat Decimal? @db.Decimal(10, 7)
  locationLng Decimal? @db.Decimal(10, 7)

  /// 외부 날씨 API 온도 (°C)
  weatherTemp Decimal? @db.Decimal(5, 2)

  /// 냉장(COOL) 측정 온도 (°C) - 적정: 2~8
  coolTemp Decimal? @db.Decimal(5, 2)
  coolOk   Boolean? // 2~8°C 이내면 true

  /// 냉동(FRZ) 측정 온도 (°C) - 적정: -18 이하
  frzTemp Decimal? @db.Decimal(5, 2)
  frzOk   Boolean? // -18°C 이하면 true

  /// 기입자
  recordedByUserId String?
  recordedByUser   User?   @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)

  memo String?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([companyId, createdAt])
}

/// 회사 소속 사용자
/// 권한(Role)에 따라 기능 접근 제어
model User {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email        String
  passwordHash String
  name         String
  role         Role    @default(WH_MANAGER)
  isActive     Boolean @default(true)
  lastLoginAt DateTime?

  /// 부서 코드 (예: SALES, ACCOUNTING, WAREHOUSE, DELIVERY)
  departmentCode String?

  /// 상위 관리자 (부서장 등)
  supervisorId String?
  supervisor   User?   @relation("UserSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  supervisees  User[]  @relation("UserSupervisor")

  /// 비밀번호 재설정용 토큰 (forgot-password 발급)
  passwordResetToken   String?
  passwordResetExpires DateTime?

  /// 개인정보 (optional)
  dateOfBirth    DateTime?
  phone          String?   // E.164
  addressLine1   String?
  addressLine2   String?
  city           String?
  stateProvince  String?
  postalCode     String?
  countryCode    String?   // ISO 3166-1 alpha-2 (KR, US 등)
  profileImageUrl String?

  refreshTokens RefreshToken[]

  /// 이 사용자가 발생시킨 재고 트랜잭션
  inventoryTxes InventoryTx[]

  /// 이 사용자가 업로드한 입고 엑셀
  inboundUploads InboundUpload[]

  /// 담당 지사 매핑 (비어있으면 전체 지사 접근)
  branchUsers BranchUser[]

  createdOutboundOrders         OutboundOrder[]     @relation("OutboundCreatedBy")
  pickedSubmittedOutboundOrders OutboundOrder[]     @relation("OutboundPickedSubmittedBy")
  verifiedOutboundOrders        OutboundOrder[]     @relation("OutboundVerifiedBy")
  shippingStartedOutboundOrders OutboundOrder[]     @relation("OutboundShippingStartedBy")
  deliveredOutboundOrders       OutboundOrder[]     @relation("OutboundDeliveredBy")
  pickAllocations               PickAllocation[]    @relation("PickPickedBy")
  returnReceivedReceipts        ReturnReceipt[]     @relation("ReturnReceivedBy")
  returnDecidedReceipts         ReturnReceipt[]     @relation("ReturnDecidedBy")
  returnCompletedReceipts       ReturnReceipt[]     @relation("ReturnCompletedBy")
  returnLineDecisions           ReturnReceiptLine[] @relation("ReturnLineDecidedBy")
  returnLineProcesses           ReturnReceiptLine[] @relation("ReturnLineProcessedBy")
  temperatureLogs              TemperatureLog[]
  createdAsns                  Asn[]                @relation("AsnCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAuditLogsTarget UserAuditLog[] @relation("AuditTargetUser")
  userAuditLogsActor  UserAuditLog[] @relation("AuditActorUser")

  @@unique([companyId, email])
  @@index([companyId])
  @@index([role])
  @@index([supervisorId])
}

/// 사용자 변경 감사 로그 (역할 변경, 활성화, 비활성화 등)
model UserAuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("AuditTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  actorUserId String
  actorUser   User     @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: Cascade)
  action      String   // ROLE_CHANGED, ACTIVATED, DEACTIVATED
  beforeValue String?  @db.Text
  afterValue  String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([actorUserId])
  @@index([createdAt])
}

/// 지사(브랜치) 단위. 지역·법인 등 회사 내 논리적 구분
/// Company → Branch → Warehouse 계층
model Branch {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String
  code String? // TOR, MTL 등

  warehouses  Warehouse[]
  asnsFrom    Asn[]        @relation("AsnFromBranch")
  asnsTo      Asn[]        @relation("AsnToBranch")
  branchUsers BranchUser[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
}

/// User ↔ Branch 담당 지사 매핑
/// 담당 지사가 없으면 전체 지사 접근, 있으면 해당 지사만 조회 가능
model BranchUser {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
  @@index([userId, branchId])
}

/// 회사 내 창고
/// Branch에 소속. 같은 Branch 내 여러 창고 가능 (DRY, COOL, FRZ 등)
model Warehouse {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  type   StorageType
  name   String
  region String @default("default") // 지역 구분 (서울, 부산, default 등)

  stocks           Stock[]
  inventoryTxLines InventoryTxLine[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  pickAllocations PickAllocation[]

  transfersFrom Transfer[] @relation("TransferFromWarehouse")
  transfersTo   Transfer[] @relation("TransferToWarehouse")
  stocktakings Stocktaking[]
  asnsFrom     Asn[]       @relation("AsnFromWarehouse")
  asnsTo       Asn[]       @relation("AsnToWarehouse")

  @@unique([branchId, type, region])
  @@index([companyId])
  @@index([branchId])
}

/// 상품 마스터
/// 동일 회사 내 itemCode는 유니크
model Item {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  itemCode String
  itemName String
  /// 품목 기본 원가 (참조/기본값용, 입고 시 미입력 시 사용)
  unitCost Decimal? @db.Decimal(18, 4)
  isActive Boolean   @default(true)

  lots Lot[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  outboundLines      OutboundLine[]
  returnReceiptLines ReturnReceiptLine[]
  asnLines           AsnLine[]

  @@unique([companyId, itemCode])
  @@index([companyId])
  @@index([itemCode])
}

/// 회사(테넌트)의 거래처(고객사). 출고/리턴의 대상.
model Customer {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerCode  String? // 고객사 코드 (선택, ERP/외부 시스템 연동용)
  customerName  String
  customerAddress String // addressLine1에 해당하는 주소

  postalCode String?
  city       String?
  state      String?
  country    String?  // ISO 3166-1 alpha-2 (KR, US, JP 등) - countryCode로 활용

  lat Decimal? @db.Decimal(10, 7)
  lng Decimal? @db.Decimal(10, 7)

  isActive Boolean @default(true)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  outboundOrders OutboundOrder[]
  returnReceipts ReturnReceipt[]

  @@unique([companyId, customerName])
  @@index([companyId])
  @@index([customerName])
}

model RefreshToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  deviceId   String?   // 프론트가 UUID로 생성해 저장해두면 좋음
  deviceName String?
  userAgent  String?
  ip         String?

  @@index([userId, revokedAt, createdAt])
  @@index([userId, deviceId])
  @@index([expiresAt])
  @@index([tokenHash])
}

/// 유통기한 단위 재고 그룹
/// expiryDate = null → 유통기한 없음 (쌀/김치 등)
model Lot {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  expiryDate DateTime? // null 가능

  stocks           Stock[]
  inventoryTxLines InventoryTxLine[]
  transferLines    TransferLine[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  pickAllocations PickAllocation[]
  stocktakingLines StocktakingLine[]

  @@unique([companyId, itemId, expiryDate])
  @@index([companyId, itemId])
  @@index([companyId, expiryDate])
}

/// 창고 + Lot 단위 현재 재고
/// onHand  : 실제 보유 수량
/// reserved: 픽으로 예약된 수량
model Stock {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Cascade)

  onHand   Decimal @default(0) @db.Decimal(18, 3)
  reserved Decimal @default(0) @db.Decimal(18, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 회사 + 창고 + Lot는 유일
  @@unique([companyId, warehouseId, lotId])
  @@index([companyId, warehouseId])
  @@index([companyId, lotId])
}

/// 모든 재고 변동은 여기 기록됨
/// 절대 수정하지 않는 Audit Log
model InventoryTx {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type InventoryTxType

  /// 작업자
  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  /// 어떤 기능에서 발생했는지 추적용
  refType String?
  refId   String?

  memo String?

  lines InventoryTxLine[]

  createdAt DateTime @default(now())

  @@index([companyId, type])
  @@index([companyId, createdAt])
}

/// 재고 변동 상세 라인
/// qtyDelta: +면 증가, -면 감소
model InventoryTxLine {
  id   String      @id @default(uuid())
  txId String
  tx   InventoryTx @relation(fields: [txId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Cascade)

  qtyDelta Decimal  @db.Decimal(18, 3)
  /// 입고 확정 시 기록된 단위 원가 (원가 리포트/감사용)
  unitCost Decimal? @db.Decimal(18, 4)

  createdAt DateTime @default(now())

  @@index([txId])
  @@index([warehouseId])
  @@index([lotId])
}

model InboundUpload {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  uploadedByUserId String?
  uploadedByUser   User?   @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  fileName    String
  status      InboundUploadStatus @default(UPLOADED)
  createdAt   DateTime            @default(now())
  confirmedAt DateTime?

  rows InboundUploadRow[]

  @@index([companyId, status])
  @@index([companyId, createdAt])
}

model InboundUploadRow {
  id       String        @id @default(uuid())
  uploadId String
  upload   InboundUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  itemCode    String
  itemName    String
  storageType StorageType
  quantity    Decimal  @db.Decimal(18, 3)
  expiryDate  DateTime?
  /// 입고 행 단위 원가 (엑셀 UnitCost 컬럼 또는 UI 입력)
  unitCost    Decimal? @db.Decimal(18, 4)

  isValid      Boolean @default(true)
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([uploadId])
  @@index([itemCode])
}

/// 출고 주문 헤더
/// plannedDate 기준으로 오늘~미래 출고 관리
model OutboundOrder {
  id        String  @id @default(uuid())
  orderNo   Int     @unique @default(autoincrement())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  plannedDate DateTime

  title  String?
  status OutboundStatus @default(DRAFT)

  createdByUserId String?
  createdByUser   User?   @relation("OutboundCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  /// PICKED(픽 완료 제출) 기록
  pickedSubmittedByUserId String?
  pickedSubmittedByUser   User?     @relation("OutboundPickedSubmittedBy", fields: [pickedSubmittedByUserId], references: [id], onDelete: SetNull)
  pickedSubmittedAt       DateTime?

  /// READY_TO_SHIP(검수 완료) 기록
  verifiedByUserId String?
  verifiedByUser   User?     @relation("OutboundVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  verifiedAt       DateTime?

  /// SHIPPING(배송 시작) 기록
  shippingStartedByUserId String?
  shippingStartedByUser   User?     @relation("OutboundShippingStartedBy", fields: [shippingStartedByUserId], references: [id], onDelete: SetNull)
  shippingStartedAt       DateTime?

  /// DELIVERED(배송 완료) 기록
  deliveredByUserId String?
  deliveredByUser   User?     @relation("OutboundDeliveredBy", fields: [deliveredByUserId], references: [id], onDelete: SetNull)
  deliveredAt       DateTime?

  memo String?

  lines OutboundLine[]
  returnReceipts ReturnReceipt[]

  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, plannedDate])
  @@index([companyId, customerId])
}

/// 출고 품목 라인
/// requestedQty : 요청 수량(오더 수량)
/// pickedQty    : 실제 픽 체크 합계(부분 픽 허용)
/// shippedQty   : 출고 처리 수량(배송/출고 완료 시점에 반영)
/// deliveredQty : 실제 배송 완료 수량(부분 배송/파손/품절 반영)
model OutboundLine {
  id      String        @id @default(uuid())
  orderId String
  order   OutboundOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  requestedQty Decimal @db.Decimal(18, 3)
  pickedQty    Decimal @default(0) @db.Decimal(18, 3)
  shippedQty   Decimal @default(0) @db.Decimal(18, 3)
  deliveredQty Decimal @default(0) @db.Decimal(18, 3)

  status OutboundLineStatus @default(ACTIVE)

  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickAllocations PickAllocation[]
  returnReceiptLines ReturnReceiptLine[]

  @@index([orderId])
  @@index([itemId])
}

/// 픽 예약 기록
/// Lot 단위로 예약해야 FEFO 가능
model PickAllocation {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  outboundLineId String
  outboundLine   OutboundLine @relation(fields: [outboundLineId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Restrict)

  /// 예약된 수량(시스템이 FEFO로 잡아둔 수량 또는 수동 지정 수량)
  qty       Decimal @db.Decimal(18, 3)
  /// 실제 픽 체크 수량(부분 픽 허용: 0~qty)
  pickedQty Decimal @default(0) @db.Decimal(18, 3)

  /// 🔹 픽 방식 (자동 / 수동)
  source       PickSource @default(AUTO_FEFO)
  manualReason String?

  pickedByUserId String?
  pickedByUser   User?     @relation("PickPickedBy", fields: [pickedByUserId], references: [id], onDelete: SetNull)
  pickedAt       DateTime?

  /// 예약 해제 여부
  isReleased Boolean   @default(false)
  releasedAt DateTime?

  /// 출고 확정 반영 여부
  isCommitted Boolean   @default(false)
  committedAt DateTime?

  createdAt DateTime @default(now())

  @@index([companyId, outboundLineId, isReleased, isCommitted])
  @@index([companyId, warehouseId, lotId])
  @@index([companyId, pickedByUserId])
  @@index([companyId, outboundLineId])
}

model ReturnReceipt {
  id        String  @id @default(uuid())
  receiptNo Int     @unique @default(autoincrement())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  outboundOrderId String?
  outboundOrder   OutboundOrder? @relation(fields: [outboundOrderId], references: [id], onDelete: SetNull)

  receivedAt DateTime     @default(now())
  status     ReturnStatus @default(RECEIVED)
  memo       String?

  receivedByUserId String?
  receivedByUser   User?   @relation("ReturnReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)

  decidedByUserId String?
  decidedByUser   User?     @relation("ReturnDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt       DateTime?

  completedByUserId String?
  completedByUser   User?     @relation("ReturnCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  completedAt       DateTime?

  lines ReturnReceiptLine[]

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, receivedAt])
  @@index([companyId, customerId])
  @@index([companyId, outboundOrderId])
}

model ReturnReceiptLine {
  id        String        @id @default(uuid())
  receiptId String
  receipt   ReturnReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  outboundLineId String?
  outboundLine   OutboundLine? @relation(fields: [outboundLineId], references: [id], onDelete: SetNull)

  storageType StorageType
  expiryDate  DateTime?
  qty         Decimal @db.Decimal(18, 3)

  // 결정(재입고/폐기)
  decision        ReturnLineDecision?
  decidedAt       DateTime?
  decidedByUserId String?
  decidedByUser   User?               @relation("ReturnLineDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  // 재고 반영(완료)
  processedAt       DateTime?
  processedByUserId String?
  processedByUser   User?     @relation("ReturnLineProcessedBy", fields: [processedByUserId], references: [id], onDelete: SetNull)

  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receiptId])
  @@index([itemId])
  @@index([itemId, expiryDate])
  @@index([outboundLineId])
}

/// 창고 간 재고 이동 요청
model Transfer {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fromWarehouseId String
  fromWarehouse   Warehouse @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouseId   String
  toWarehouse     Warehouse @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)

  status TransferStatus @default(PENDING)
  memo   String?

  requestedByUserId String?
  confirmedByUserId String?
  confirmedAt       DateTime?

  lines TransferLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

/// 창고 간 재고 이동 라인 (Lot 단위)
model TransferLine {
  id         String  @id @default(uuid())
  transferId String
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Restrict)

  qty Decimal @db.Decimal(18, 3)

  createdAt DateTime @default(now())

  @@index([transferId])
  @@index([lotId])
}

/// 입고 예정(ASN). 지사 간 이동 시 입고 신청 → 출고 → 입고 흐름
model Asn {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fromBranchId    String?
  fromBranch      Branch?    @relation("AsnFromBranch", fields: [fromBranchId], references: [id], onDelete: SetNull)
  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("AsnFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)

  toBranchId    String
  toBranch      Branch    @relation("AsnToBranch", fields: [toBranchId], references: [id], onDelete: Restrict)
  toWarehouseId String
  toWarehouse   Warehouse @relation("AsnToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)

  expectedDate DateTime
  status      AsnStatus @default(PENDING)

  createdByUserId String?
  createdByUser   User?   @relation("AsnCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  receivedAt DateTime?

  lines AsnLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@index([toBranchId])
  @@index([toWarehouseId])
  @@index([expectedDate])
}

/// 입고 예정 라인 (품목 단위)
model AsnLine {
  id     String @id @default(uuid())
  asnId  String
  asn    Asn    @relation(fields: [asnId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  quantity  Decimal   @db.Decimal(18, 3)
  expiryDate DateTime?

  createdAt DateTime @default(now())

  @@index([asnId])
  @@index([itemId])
}

/// 재고 실사 계획
model Stocktaking {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  status StocktakingStatus @default(DRAFT)
  memo   String?

  createdByUserId String?
  confirmedByUserId String?
  confirmedAt      DateTime?

  lines StocktakingLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@index([warehouseId])
}

/// 재고 실사 라인 (실제 수량 기입)
model StocktakingLine {
  id           String  @id @default(uuid())
  stocktakingId String
  stocktaking   Stocktaking @relation(fields: [stocktakingId], references: [id], onDelete: Cascade)

  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Restrict)

  /// 시스템 재고 (실사 시점)
  systemQty Decimal @db.Decimal(18, 3)
  /// 실사 입력 수량
  actualQty Decimal? @db.Decimal(18, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stocktakingId, lotId])
  @@index([stocktakingId])
  @@index([lotId])
}
