# ===========================================
# WarehouseHub 환경 변수 예시
# 사용법: cp .env.example .env 후 값 수정
# ===========================================
#
# [필수] 프로덕션 배포 시 반드시 설정
# [선택] 미설정 시 기본값 사용 (로컬 개발용)
#
# ===========================================

# ========== 필수 (모든 환경) ==========
# PostgreSQL 연결 문자열. schema=public 권장
DATABASE_URL="postgresql://warehousehub:warehousehub@localhost:5432/warehousehub?schema=public"

# JWT 서명 시크릿. 32자 이상 랜덤 문자열. 프로덕션에서는 반드시 강력한 값으로 변경
# 기본값(change_me_long_random_string) 사용 시 프로덕션에서 서버 시작 거부됨
JWT_SECRET=change_me_long_random_string

# ========== 선택 (API) ==========
API_PORT=3001

# ========== 선택 (Web) ==========
# 웹 프론트에서 API 호출 시 사용하는 base URL. 웹과 API가 다른 도메인일 때 필수
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# 비밀번호 재설정 링크의 base URL. API에서 이메일 발송 시 사용. 미설정 시 localhost:3000 사용
APP_URL=http://localhost:3000

# 웹 프론트 출처와 동일. 비밀번호 재설정 링크 등 검증용
# FRONTEND_URL= (APP_URL과 동일하게 설정해도 됨)

# ========== 인증/쿠키 ==========
# 웹 프론트 출처 (회원가입 등 서버 검증용)
WEB_ORIGIN=http://localhost:3000

# CORS 허용 출처. 쉼표로 구분 (예: http://localhost:3000,https://app.example.com)
CORS_ORIGIN=http://localhost:3000

# 쿠키 도메인. 서브도메인 공유 시 .example.com 형태로 설정. 로컬은 비워둠
COOKIE_DOMAIN=

# true면 HTTPS에서만 쿠키 전송. 개발 환경은 false
COOKIE_SECURE=false

# lax(기본) | strict | none. 크로스 사이트 요청 시 none 필요
COOKIE_SAMESITE=lax

# 사용자당 최대 동시 로그인 디바이스 수. 초과 시 기존 세션 revoke
AUTH_MAX_ACTIVE_DEVICES=3

# ========== 이메일 (프로덕션 비밀번호 재설정 시 필수) ==========
# NODE_ENV=production 시 실제 SMTP로 발송. 개발 환경에서는 콘솔 로그만 출력
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
# 발신 이메일 주소
MAIL_FROM=noreply@warehousehub.example.com
# SendGrid 등 외부 서비스 사용 시 (선택)
# SENDGRID_API_KEY=SG.xxx

# ========== Swagger ==========
# NODE_ENV=production에서는 기본 비활성화. SWAGGER_ENABLED=true로 명시 시 활성화
# SWAGGER_ENABLED=false

# ========== 로깅 ==========
NODE_ENV=development
# debug | info | warn | error
LOG_LEVEL=debug
